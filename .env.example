# Gemini API
GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Gmail (paths relative to project root - for local development)
GMAIL_CREDENTIALS_PATH=credentials/credentials.json
GMAIL_TOKEN_PATH=credentials/token.json

# Gmail (JSON strings - for production/cloud deployment)
# GMAIL_TOKEN_JSON={"token": "...", "refresh_token": "...", ...}
# GMAIL_CREDENTIALS_JSON={"installed": {"client_id": "...", ...}}

# Filters
GMAIL_LABELS=SES案件
GMAIL_KEYWORDS=案件,募集,エンジニア,SE,PG

# Processing
BATCH_SIZE=50
MAX_EMAILS_PER_FETCH=500
GEMINI_DELAY_SECONDS=1.0

# Database (SQLite - local development)
DB_PATH=data/gmail_analyzer.db

# Database (PostgreSQL - production)
# DATABASE_URL=postgresql://user:password@host:port/dbname

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000
